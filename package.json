{
  "name": "huginn-nodeboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "NODEBOARD_DB=${NODEBOARD_DB:-sqlite:///./nodeboard-backend/nodeboard.db} nodeboard-backend/.venv/bin/uvicorn app.main:app --reload --port 8001 --app-dir nodeboard-backend",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:api": "nodeboard-backend/.venv/bin/python -m pytest nodeboard-backend/tests"
  },
  "dependencies": {
    "@tailwindcss/vite": "latest",
    "@vitejs/plugin-react": "latest",
    "html-to-image": "^1.11.11",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "jsdom": "^29.1.1",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
